<Window x:Class="PlugHub.ClearHeightAnalysis.UI.ClearHeightAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="净高分析设置"
        Width="620" Height="640"
        MinWidth="580" MinHeight="620"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Microsoft YaHei"
        FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="FieldTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2B579A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8,20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8,20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,20,20,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="净高分析设置" FontSize="18" FontWeight="SemiBold" Foreground="#2B579A"/>
                <TextBlock Text="基于建筑外轮廓生成网格，通过构件投影覆盖计算每格最不利净高。"
                           Foreground="#666666" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="楼层名称" VerticalAlignment="Center" Foreground="#333333"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="LevelNameTextBox" Style="{StaticResource FieldTextBox}" Text="当前楼层"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="楼层标高 mm" VerticalAlignment="Center" Foreground="#333333" Margin="16,0,0,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="LevelElevationTextBox" Style="{StaticResource FieldTextBox}" Text="0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="网格尺寸 mm" VerticalAlignment="Center" Foreground="#333333" Margin="0,12,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="GridSizeTextBox" Style="{StaticResource FieldTextBox}" Text="1000" Margin="0,12,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="净高阈值 mm" VerticalAlignment="Center" Foreground="#333333" Margin="16,12,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="ClearHeightThresholdTextBox" Style="{StaticResource FieldTextBox}" Text="3000" Margin="0,12,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="完成面偏移 mm" VerticalAlignment="Center" Foreground="#333333" Margin="0,12,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="FinishFloorOffsetTextBox" Style="{StaticResource FieldTextBox}" Text="0" Margin="0,12,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="搜索高度 mm" VerticalAlignment="Center" Foreground="#333333" Margin="16,12,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="SearchHeightTextBox" Style="{StaticResource FieldTextBox}" Text="6000" Margin="0,12,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="最小管径 mm" VerticalAlignment="Center" Foreground="#333333" Margin="0,12,0,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="MinimumPipeDiameterTextBox" Style="{StaticResource FieldTextBox}" Text="50" Margin="0,12,0,0"/>
                <CheckBox Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" x:Name="UseCropFallbackCheckBox" Content="无法识别楼板时使用当前视图裁剪框" IsChecked="True" Margin="16,14,0,0" Foreground="#333333"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <WrapPanel>
                <CheckBox x:Name="IncludeCurrentModelCheckBox" Content="包含当前模型" IsChecked="True" Margin="0,0,22,8" Foreground="#333333"/>
                <CheckBox x:Name="IncludeLinkedModelsCheckBox" Content="包含链接模型" IsChecked="True" Margin="0,0,22,8" Foreground="#333333"/>
                <CheckBox x:Name="IncludeCeilingsCheckBox" Content="包含吊顶" IsChecked="True" Margin="0,0,22,8" Foreground="#333333"/>
                <CheckBox x:Name="IncludeMepCheckBox" Content="包含机电" IsChecked="True" Margin="0,0,22,8" Foreground="#333333"/>
                <CheckBox x:Name="RenderOnlyProblemCellsCheckBox" Content="只显示问题网格" IsChecked="True" Margin="0,0,22,8" Foreground="#333333"/>
            </WrapPanel>
        </Border>

        <TextBlock Grid.Row="3" x:Name="ValidationText" Foreground="#A33" FontSize="12" Margin="4,0,0,0" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="CancelButton_Click" Margin="0,0,10,0"/>
            <Button Content="开始分析" Style="{StaticResource PrimaryButton}" Click="AnalyzeButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
